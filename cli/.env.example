EXECUTION_BACKEND=openai_compatible
OPENROUTER_API_KEY=your_openrouter_api_key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
ARXIV2PRODUCT_MODEL=anthropic/claude-sonnet-4
# Legacy backend:
# AGENTICA_API_KEY=your_agentica_api_key
SERPER_API_KEY=your_serper_api_key
EXA_API_KEY=your_exa_api_key
SEARCH_PROVIDER_MODE=auto
SEARCH_NUM_RESULTS=3
SEARCH_TIMEOUT_SECONDS=8
SEARCH_MAX_CALLS_PER_AGENT=2
SEARCH_ENABLE_FALLBACK=0
PIPELINE_SPEED_PROFILE=balanced
AGENT_PHASE_TIMEOUT_SECONDS=480
ENABLE_REDTEAM_SEARCH=0
ENABLE_AGENT_LOGS=0
ARXIV2PRODUCT_SERVICE_DB=data/service.db
# Optional: override the hosted Agentica API endpoint.
# AGENTICA_BASE_URL=https://api.platform.symbolica.ai
# Optional: connect directly to a local Agentica session manager.
# S_M_BASE_URL=http://localhost:2345
